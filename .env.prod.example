# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
CORS_ORIGINS=https://yourdomain.com
LOG_LEVEL=log
LOG_PRETTY=false
LOG_HTTP_BODY=false
LOG_WS_PAYLOAD=false

# ── Docker / Ingress (compose contract) ──────────────────────────────────────
NGINX_LISTEN_PORT=80
NGINX_HOST_PORT=800
NGINX_BIND_IP=127.0.0.1

# ── Database (external managed postgres) ─────────────────────────────────────
DATABASE_URL=postgres://postgres:password@db-host:5432/market_place_db
DATABASE_SSL=true
DATABASE_POOL_MAX=20

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change_this_access_secret
JWT_REFRESH_SECRET=change_this_refresh_secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# ── OTP / Auth ────────────────────────────────────────────────────────────────
ADMIN_PHONE=+201000000000
ADMIN_PASSWORD=ChangeMe123
OTP_PROVIDER=resend
OTP_TTL_MINUTES=10
OTP_DEV_MODE=false
OTP_SIGNING_SECRET=change_this_otp_signing_secret

# ── Resend (required when OTP_PROVIDER=resend) ───────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=no-reply@example.com
RESEND_OTP_SUBJECT=Your verification code

# ── File Storage ──────────────────────────────────────────────────────────────
STORAGE_PROVIDER=cloudinary
STORAGE_BUCKET=market-media
STORAGE_PUBLIC_BASE_URL=https://your-cdn.example.com
STORAGE_UPLOAD_TTL_SECONDS=600
STORAGE_SIGNING_SECRET=change_this_storage_signing_secret

# ── Cloudinary (required when STORAGE_PROVIDER=cloudinary) ───────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Rate Limiting ─────────────────────────────────────────────────────────────
THROTTLE_TTL=60000
THROTTLE_LIMIT=120
THROTTLE_DEV_BYPASS=false

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379
