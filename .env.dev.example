# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
CORS_ORIGINS=http://localhost:3000,http://localhost:800
LOG_LEVEL=log
LOG_PRETTY=true
LOG_HTTP_BODY=true
LOG_WS_PAYLOAD=true

# ── Docker / Ingress (compose contract) ──────────────────────────────────────
NGINX_LISTEN_PORT=80
NGINX_HOST_PORT=800
NGINX_BIND_IP=127.0.0.1

# ── Database (internal postgres container in docker-compose.dev.yml) ─────────
POSTGRES_DB=market_place_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgres://postgres:postgres@postgres:5432/market_place_db
DATABASE_SSL=false
DATABASE_POOL_MAX=20

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change_this_access_secret
JWT_REFRESH_SECRET=change_this_refresh_secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# ── OTP / Auth ────────────────────────────────────────────────────────────────
ADMIN_PHONE=+201000000000
ADMIN_PASSWORD=ChangeMe123
# Deprecated: use users.is_admin as source of truth.
ADMIN_PHONES=
OTP_PROVIDER=console
OTP_TTL_MINUTES=10
OTP_DEV_MODE=true
OTP_SIGNING_SECRET=change_this_otp_signing_secret

# ── Resend (required only when OTP_PROVIDER=resend) ──────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=no-reply@example.com
RESEND_OTP_SUBJECT='Your verification code'

# ── File Storage ──────────────────────────────────────────────────────────────
STORAGE_PROVIDER=cloudinary
STORAGE_BUCKET=market-media
STORAGE_PUBLIC_BASE_URL=https://your-cdn.example.com
STORAGE_UPLOAD_TTL_SECONDS=600
STORAGE_SIGNING_SECRET=change_this_storage_signing_secret

# ── Cloudinary (required when STORAGE_PROVIDER=cloudinary) ───────────────────
CLOUDINARY_CLOUD_NAME=replace_with_cloudinary_cloud_name
CLOUDINARY_API_KEY=replace_with_cloudinary_api_key
CLOUDINARY_API_SECRET=replace_with_cloudinary_api_secret

# ── Rate Limiting ─────────────────────────────────────────────────────────────
THROTTLE_TTL=60000
THROTTLE_LIMIT=120
THROTTLE_DEV_BYPASS=true

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Seeder Runtime (optional) ────────────────────────────────────────────────
BASE_URL=http://localhost:800
SEED_PROFILE=medium
SEED_TIMEOUT_MS=12000

# ── Script/Test Runtime (optional) ───────────────────────────────────────────
ADMIN_EMAIL=admin@example.com
AUTH_TEST_PASSWORD=ChangeMe123
AUTH_TEST_TIMEOUT_MS=12000
PROFILE_TEST_PASSWORD=ChangeMe123
PROFILE_TEST_NEW_PASSWORD=ChangeMe1234
PROFILE_TEST_TIMEOUT_MS=12000
CHAT_TEST_TIMEOUT_MS=12000
CHAT_TEST_MESSAGE_COUNT=2
CHAT_TEST_MESSAGE_PREFIX=chat-test-message
CHAT_TEST_LOG_DIR=logs/chat-socket-test
CHAT_TEST_OTP=000000
KAYAN_FOLLOWUP_TEST_TIMEOUT_MS=20000
KAYAN_FOLLOWUP_TEST_VERBOSE=true
KAYAN_FOLLOWUP_TEST_NEGATIVE=true
KAYAN_FOLLOWUP_TEST_CONTINUE_ON_FAIL=false

# ── Simulation Runtime (optional) ────────────────────────────────────────────
SIM_MODE=all
SIM_TIMEOUT_MS=12000
SIM_NEGATIVE_TESTS=true
SIM_CONTINUE_ON_FAIL=false
SIM_ENABLE_CONCURRENT_FLOW=false
SIM_CONCURRENT_USERS=5
SIM_CONCURRENT_STAGGER_MS=150
SIM_CHAT_PAIRS=2
SIM_CONCURRENT_MESSAGES_PER_PAIR=2
SIM_429_RETRY_ATTEMPTS=2
SIM_429_RETRY_WAIT_MS=1000
SIM_RETRY_ABORT_ATTEMPTS=3
SIM_RETRY_ABORT_BASE_MS=400
SIM_ALLOW_CONTACTS_POST=false
SIM_ASSERT_CONTRACT=true
SIM_ASSERT_STRICT=false
SIM_ASSERT_WS_PAYLOAD=false
SIM_REAL_UPLOAD=false
SIM_REAL_IMAGE_PATH=
SIM_RUN_ID=
SIM_SEED_DRY_RUN=false
SIM_SEED_MAX_ITERATIONS=1000
SIM_SEED_MAX_DURATION_MS=600000
SIM_TARGET_USERS=20
SIM_TARGET_PRODUCTS=20
SIM_TARGET_FAVORITES=20
SIM_TARGET_CONTACTS=20
SIM_TARGET_CONVERSATIONS=20
SIM_TARGET_MESSAGES=40
SIM_TARGET_REPORTS=20
SIM_TARGET_RATINGS=20
SIM_TARGET_BLOCKS=20
SIM_TARGET_FILES=20
SIM_TARGET_ADMIN_WARNINGS=10
SIM_TARGET_ADMIN_REPORT_ACTIONS=10
SIM_POST_QUOTA_AUTH_REGISTER=10
SIM_POST_QUOTA_AUTH_VERIFY=10
SIM_POST_QUOTA_AUTH_RESEND_OTP=10
SIM_POST_QUOTA_AUTH_LOGIN=20
SIM_POST_QUOTA_AUTH_PASSWORD_REQUEST_OTP=10
SIM_POST_QUOTA_AUTH_PASSWORD_RESET=10
SIM_POST_QUOTA_AUTH_REFRESH=20
SIM_POST_QUOTA_AUTH_LOGOUT=20
SIM_POST_QUOTA_PRODUCTS=30
SIM_POST_QUOTA_FAVORITES=40
SIM_POST_QUOTA_CONTACTS=30
SIM_POST_QUOTA_CHAT_CONVERSATIONS=30
SIM_POST_QUOTA_REPORTS=30
SIM_POST_QUOTA_RATINGS=30
SIM_POST_QUOTA_BLOCKS=20
SIM_POST_QUOTA_FILES_UPLOAD_INTENT=30
SIM_POST_QUOTA_ADMIN_WARNINGS=20
SIM_POST_QUOTA_ADMIN_PROMOTE=10
SIM_POST_QUOTA_ADMIN_CATEGORIES=20
SIM_KAYAN_TIMEOUT_MS=12000
SIM_KAYAN_VERBOSE=true
SIM_KAYAN_NEGATIVE_TESTS=true
SIM_KAYAN_CONTINUE_ON_FAIL=false
SIM_KAYAN_FAULTS_TIMEOUT_MS=12000
SIM_KAYAN_FAULTS_VERBOSE=true
SIM_KAYAN_FAULTS_NEGATIVE_TESTS=true
SIM_KAYAN_FAULTS_CONTINUE_ON_FAIL=false
SIM_KAYAN_SERVICES_TIMEOUT_MS=12000
SIM_KAYAN_SERVICES_VERBOSE=true
SIM_KAYAN_SERVICES_NEGATIVE_TESTS=true
SIM_KAYAN_SERVICES_CONTINUE_ON_FAIL=false
SIM_KAYAN_GALLERY_TIMEOUT_MS=12000
SIM_KAYAN_GALLERY_VERBOSE=true
SIM_KAYAN_GALLERY_NEGATIVE_TESTS=true
SIM_KAYAN_GALLERY_CONTINUE_ON_FAIL=false
SIM_KAYAN_GALLERY_UPLOAD_MODE=mock
SIM_KAYAN_GALLERY_PREFLIGHT_ATTEMPTS=3
SIM_KAYAN_GALLERY_PREFLIGHT_DELAY_MS=1000
