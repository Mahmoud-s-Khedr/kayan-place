# This project now uses environment-specific templates.
# Choose one and copy it to .env:
#   cp .env.dev.example .env   # local development with docker-compose.dev.yml (includes postgres)
#   cp .env.prod.example .env  # production with docker-compose.prod.yml (external postgres)

# You can also keep this file as your active .env if you fill all required values.
# Minimal required values are shown below for quick start:

NODE_ENV=development
PORT=3000
DATABASE_URL=postgres://postgres:postgres@postgres:5432/market_place_db
DATABASE_SSL=false
JWT_ACCESS_SECRET=change_this_access_secret
JWT_REFRESH_SECRET=change_this_refresh_secret
OTP_SIGNING_SECRET=change_this_otp_signing_secret
STORAGE_SIGNING_SECRET=change_this_storage_signing_secret
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
