# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
CORS_ORIGINS=https://yourdomain.com
LOG_LEVEL=log
LOG_PRETTY=true
LOG_HTTP_BODY=true
LOG_WS_PAYLOAD=true

# ── Docker / Ingress (compose contract) ──────────────────────────────────────
# PORT controls app listen/expose and nginx upstream target.
# Nginx listens on NGINX_LISTEN_PORT and publishes NGINX_HOST_PORT on NGINX_BIND_IP.
NGINX_LISTEN_PORT=80
NGINX_HOST_PORT=800
NGINX_BIND_IP=127.0.0.1

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://postgres@host.docker.internal:15432/market_place_db
DATABASE_SSL=true
DATABASE_POOL_MAX=20

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change_this_access_secret
JWT_REFRESH_SECRET=change_this_refresh_secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# ── OTP / Auth ────────────────────────────────────────────────────────────────
# Deprecated and non-authoritative for admin auth; kept for backward compatibility.
ADMIN_PHONE=+201000000000
ADMIN_PASSWORD=ChangeMe123
OTP_PROVIDER=akedly
OTP_TTL_MINUTES=10
OTP_DEV_MODE=false
OTP_SIGNING_SECRET=change_this_otp_signing_secret

# ── Akedly Shield (required when OTP_PROVIDER=akedly) ────────────────────────
AKEDLY_API_KEY=
AKEDLY_PIPELINE_ID=
AKEDLY_BASE_URL=https://api.akedly.io

# ── File Storage ──────────────────────────────────────────────────────────────
STORAGE_PROVIDER=cloudinary
STORAGE_BUCKET=market-media
STORAGE_PUBLIC_BASE_URL=https://your-cdn.example.com  # Not used for Cloudinary; read URLs are derived from CLOUDINARY_CLOUD_NAME + MIME type at runtime
STORAGE_UPLOAD_TTL_SECONDS=600
STORAGE_SIGNING_SECRET=change_this_storage_signing_secret

# ── Cloudinary (required when STORAGE_PROVIDER=cloudinary) ───────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Rate Limiting ─────────────────────────────────────────────────────────────
THROTTLE_TTL=60000
THROTTLE_LIMIT=120
THROTTLE_DEV_BYPASS=false

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Seeder Runtime (optional; used by scripts/seed-dev.ts) ──────────────────
BASE_URL=http://localhost
SEED_PROFILE=medium
SEED_TIMEOUT_MS=12000
